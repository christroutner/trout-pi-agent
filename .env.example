# Repository roots (defaults: siblings of trout-pi-agent — ../pi-backup, etc.)
# PI_BACKUP_ROOT=/absolute/path/to/pi-backup
# PI_TELEGRAM_EXTENSION_ROOT=/absolute/path/to/pi-telegram-extension
# PI_MEMORY_ROOT=/absolute/path/to/pi-memory
# PI_MCP_ADAPTER_ROOT=/absolute/path/to/pi-mcp-adapter

# Memory files for pi-memory (default: ${PI_BACKUP_ROOT}/memory if PI_BACKUP_ROOT is set)
# PI_MEMORY_DIR=/absolute/path/to/pi-backup/memory

# Telegram (pi-telegram-extension) — required for the bot to start
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=123456789
# TELEGRAM_ALLOWED_GROUP_CHAT_IDS=
# TELEGRAM_ALLOWLIST_ENABLED=true

# Optional pi-memory / qmd
# PI_MEMORY_NO_SEARCH=0
# PI_MEMORY_QMD_UPDATE=background
